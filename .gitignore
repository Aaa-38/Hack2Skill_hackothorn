# ============================================================================
# Redrob Hackathon - .gitignore
# Python 3.12 | AI/ML Ranking Pipeline | Windows + Linux
# ============================================================================

# ----------------------------------------------------------------------------
# Python bytecode / compiled files
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
build/
dist/
pip-wheel-metadata/

# ----------------------------------------------------------------------------
# Virtual Environments
# ----------------------------------------------------------------------------
.venv/
venv/
env/

# ----------------------------------------------------------------------------
# Python Version Managers
# ----------------------------------------------------------------------------
.python-version

# ----------------------------------------------------------------------------
# IDE / Editors
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.code-workspace
*.swp
*.swo

# ----------------------------------------------------------------------------
# Operating System Files
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ----------------------------------------------------------------------------
# Testing / Coverage / Linting
# ----------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.tox/
.nox/
.coverage
coverage.xml
htmlcov/

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
*.log
logs/

# ----------------------------------------------------------------------------
# Generated Outputs
# ----------------------------------------------------------------------------
output/
reports/
cache/
tmp/
temp/
artifacts/
release/

# ----------------------------------------------------------------------------
# Model / Embedding / ML Artifacts
# ----------------------------------------------------------------------------
*.npy
*.npz
*.pkl
*.pickle
*.joblib
*.onnx
*.bin
*.pt
*.pth
*.ckpt

# ----------------------------------------------------------------------------
# Profiling / Benchmarking
# ----------------------------------------------------------------------------
*.prof
*.lprof

# ----------------------------------------------------------------------------
# Local Databases
# ----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# ----------------------------------------------------------------------------
# Large Datasets (Do NOT track generated/raw datasets)
# ----------------------------------------------------------------------------
data/*.jsonl
data/*.jsonl.gz
data/*.csv
data/*.parquet

# ----------------------------------------------------------------------------
# Generated Submission Files
# ----------------------------------------------------------------------------
submission.csv

# ----------------------------------------------------------------------------
# Generated Reports / Integrity Artifacts
# ----------------------------------------------------------------------------
quality_report.json
manifest.json
fingerprints.jsonl

# ----------------------------------------------------------------------------
# Jupyter
# ----------------------------------------------------------------------------
.ipynb_checkpoints/

# ----------------------------------------------------------------------------
# Secrets / Local Environment
# ----------------------------------------------------------------------------
.env
.env.*
.envrc
.direnv/
*.key
*.pem
*.secret

# ----------------------------------------------------------------------------
# Claude Code
# ----------------------------------------------------------------------------
.claude/
CLAUDE.md

# Keep these tracked
# ============================================================================
!data/sample_candidates.json
!data/candidate_schema.json
!submission_metadata.yaml
!README.md
!requirements.txt

!rank.py
!validate_submission.py
!pyproject.toml

# Generated reports
transparency/*.json

# Generated error files
errors/*.jsonl